# Copy to `.env` and fill in. `.env` is git-ignored.
# You only need the key(s) for the provider(s) you actually use.

# --- OpenAI / OpenAI-compatible (default) ---
OPENAI_API_KEY=
# Override the base URL to use a proxy or an OpenAI-compatible gateway:
# OPENAI_BASE_URL=https://api.openai.com/v1
# DeepSeek can be used through the OpenAI-compatible client by setting the key
# locally in OPENAI_API_KEY and the base URL to https://api.deepseek.com.
# Prefer deepseek-v4-flash or deepseek-v4-pro in config/config.yaml for new runs.
# Never commit real keys or local config files.

# --- Anthropic (optional, for Claude Opus/Sonnet comparison) ---
ANTHROPIC_API_KEY=

# --- Google Gemini (optional) ---
GEMINI_API_KEY=

# Optional HTTP(S) proxy for API calls
# HTTP_PROXY=
# HTTPS_PROXY=
