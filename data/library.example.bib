@article{stout2022beefy9,
  title = {A beefy-9 serum-free medium supports bovine satellite cell expansion without loss of myogenicity},
  author = {Stout, Andrew J. and Mirliani, Addison B. and Rittenberg, Miriam L. and Kaplan, David L.},
  year = {2022},
  journal = {Communications Biology},
  doi = {10.1038/s42003-022-03423-8},
  abstract = {B8 is adapted for bovine satellite cells through the addition of a single component, recombinant albumin, which renders it suitable for long-term satellite cell expansion without sacrificing myogenicity.}
}

@article{oneill2022spentmedia,
  title = {Spent media analysis suggests cultivated meat media will require species and cell-type optimization},
  author = {O'Neill, Edward N. and Ansel, James C. and Kwong, Grace A. and others},
  year = {2022},
  journal = {npj Science of Food},
  doi = {10.1038/s41538-022-00157-z},
  abstract = {Our results indicate that no one medium is likely ideal and cost effective to culture multiple cell types and that novel methods to streamline media optimization efforts will be important for the industry to develop.}
}

@article{messmer2022serumfree,
  title = {A serum-free media formulation for cultured meat production supports bovine satellite cell differentiation},
  author = {Messmer, Tobias and Klevernic, Iris and Furquim, Carolina and others},
  year = {2022},
  journal = {Nature Food},
  doi = {10.1038/s43016-021-00419-1},
  abstract = {The serum-free differentiation media supported the fabrication of three-dimensional bioartificial muscle constructs, demonstrating its suitability for cultured beef production.}
}

@article{kolkmann2022defined,
  title = {Development of a chemically defined medium for in vitro expansion of primary bovine satellite cells},
  author = {Kolkmann, Anna M. and Van Essen, Anon and Post, Mark J. and Moutsatsou, Panagiota},
  year = {2022},
  journal = {Frontiers in Bioengineering and Biotechnology},
  doi = {10.3389/fbioe.2022.895289},
  abstract = {The study develops a chemically defined, cost-efficient serum-free and animal-free medium that supports bovine myoblast attachment and expansion while maintaining differentiation capacity.}
}
